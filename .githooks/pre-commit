#!/usr/bin/env bash
# -----------------------------------------------------------
# pre-commit hook
# Syncs workflow templates from  workflows/  into
# .github/workflows/  based on the list in
# .github/workflows/sync-from-root-workflows
#
# Workflows listed in that file are copied from workflows/.
# Synced workflows that are no longer listed get deleted.
# -----------------------------------------------------------

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"

SRC_DIR="$REPO_ROOT/workflows"
DST_DIR="$REPO_ROOT/.github/workflows"
SYNC_FILE="$DST_DIR/sync-from-root-workflows"

if [[ ! -f "$SYNC_FILE" ]]; then
  echo "⚠  pre-commit: $SYNC_FILE not found — skipping workflow sync"
  exit 0
fi

# ── read sync list (skip blank lines and comments) ─────────
SYNC_WORKFLOWS=()
while IFS= read -r line; do
  line="${line%%#*}"       # strip inline comments
  line="${line// /}"       # trim whitespace
  [[ -z "$line" ]] && continue
  SYNC_WORKFLOWS+=("$line")
done < "$SYNC_FILE"

if [[ ${#SYNC_WORKFLOWS[@]} -eq 0 ]]; then
  echo "⚠  pre-commit: sync list is empty — skipping"
  exit 0
fi

dirty=0

# ── sync listed workflows ─────────────────────────────────
mkdir -p "$DST_DIR"

for wf in "${SYNC_WORKFLOWS[@]}"; do
  src="$SRC_DIR/$wf"
  dst="$DST_DIR/$wf"

  if [[ ! -f "$src" ]]; then
    echo "⚠  pre-commit: source not found — $src  (skipped)"
    continue
  fi

  if [[ ! -f "$dst" ]] || ! diff -q "$src" "$dst" > /dev/null 2>&1; then
    cp "$src" "$dst"
    git add "$dst"
    dirty=1
    echo "✓  pre-commit: synced $wf → .github/workflows/"
  fi
done

# ── delete workflows no longer in sync list ────────────────
for dst in "$DST_DIR"/*.yml; do
  [[ ! -f "$dst" ]] && continue
  wf="$(basename "$dst")"

  # check if this file has a matching source in workflows/
  [[ ! -f "$SRC_DIR/$wf" ]] && continue

  # if it came from workflows/ but is no longer in the sync list, delete it
  in_list=0
  for listed in "${SYNC_WORKFLOWS[@]}"; do
    if [[ "$listed" == "$wf" ]]; then
      in_list=1
      break
    fi
  done

  if [[ "$in_list" -eq 0 ]]; then
    git rm -f "$dst" 2>/dev/null || rm -f "$dst"
    dirty=1
    echo "✗  pre-commit: removed $wf (no longer in sync list)"
  fi
done

if [[ "$dirty" -eq 1 ]]; then
  echo "✓  pre-commit: staged workflow changes into this commit"
fi

exit 0

